rules_version = '2';

// Portal Flux — controle de acesso por papéis validado no backend (RNF Segurança).
// Papéis cumulativos lidos do documento users/{uid}: 'user' | 'avaliador' | 'admin'.
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function meDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Conta existente e ativa (RF-04: desativada perde o acesso imediatamente)
    function isActive() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && meDoc().ativo == true;
    }

    function hasRole(r) {
      return isActive() && r in meDoc().roles;
    }

    // Papéis por área ('admin' é o valor legado = hubAdmin + fluxAdmin):
    // hubAdmin administra o portal (contas, domínios, ferramentas);
    // fluxAdmin administra o Flux (ciclos, triagem, acessos, papéis do Flux).
    function ehHubAdmin() {
      return isActive() && ('hubAdmin' in meDoc().roles || 'admin' in meDoc().roles);
    }

    function ehFluxAdmin() {
      return isActive() && ('fluxAdmin' in meDoc().roles || 'admin' in meDoc().roles);
    }

    function emailDomain() {
      return request.auth.token.email.split('@')[1];
    }

    function allowedDomains() {
      return get(/databases/$(database)/documents/config/portal).data.domains;
    }

    // ── Bootstrap do primeiro acesso: o app grava bootstrap/{uid} quando
    //    config/portal não existe; a Function valida o domínio e provisiona.
    //    Só o próprio usuário cria, com o e-mail verdadeiro do token. ──
    match /bootstrap/{uid} {
      allow create: if signedIn()
        && request.auth.uid == uid
        && request.resource.data.email == request.auth.token.email;
    }

    // ── Comandos administrativos processados por Function (encerrar ciclo:
    //    admin do Flux; restaurar ferramentas: admin do hub) — em nome próprio. ──
    match /comandos/{comandoId} {
      allow create: if (ehFluxAdmin() || ehHubAdmin())
        && request.resource.data.por == request.auth.uid;
      allow read: if ehFluxAdmin() || ehHubAdmin();
    }

    // ── Configuração do portal (domínios liberados — RF-02/RF-56) ──
    match /config/portal {
      // leitura antes do perfil existir: necessária para orientar o primeiro login
      allow get: if signedIn();
      allow write: if ehHubAdmin()
        && request.resource.data.domains is list;
    }

    // ── Usuários (RF-03, RF-07, RF-55) ──
    match /users/{userId} {
      // o próprio usuário sempre pode ler seu doc (fluxo de primeiro login)
      allow get: if signedIn() && (request.auth.uid == userId || isActive());
      allow list: if isActive();

      // RF-03: criação automática no primeiro login, com domínio autorizado
      allow create: if signedIn()
        && request.auth.uid == userId
        && request.resource.data.email == request.auth.token.email
        && emailDomain() in allowedDomains()
        && request.resource.data.roles == ['user']
        && request.resource.data.ativo == true;

      // RF-07: o usuário edita o próprio perfil (nunca e-mail, papéis ou status)
      allow update: if signedIn() && request.auth.uid == userId
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['nome', 'cargo', 'empresa', 'depto', 'niver', 'apres', 'foto']);

      // RF-55 (revisto): admin do HUB gere contas (ativo) e papéis do portal;
      // admin do FLUX gere apenas papéis (comitê/fluxAdmin, via UI do Flux).
      // Ninguém desativa a própria conta.
      allow update: if ehHubAdmin()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['roles', 'ativo'])
        && (request.auth.uid != userId
            || !('ativo' in request.resource.data.diff(resource.data).affectedKeys()));
      allow update: if ehFluxAdmin()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['roles']);
    }

    // ── Ciclos (RF-12, RF-58: somente administradores do Flux) ──
    match /cycles/{cycleId} {
      allow read: if isActive();
      allow create, update: if ehFluxAdmin();
    }

    // ── Projetos do Flux ──
    match /projects/{projectId} {
      // RF-29/RF-33: kanban e ficha públicos para qualquer usuário logado
      allow read: if isActive();

      // RF-17/RF-21/RF-23: pitch criado pelo titular, sem tier/resultado/reprovação
      allow create: if isActive()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.tier == null
        && request.resource.data.resultado == null
        && !('reprovado' in request.resource.data && request.resource.data.reprovado == true);

      // RF-22: exclusão pelo titular apenas sem resultado registrado
      allow delete: if isActive()
        && resource.data.uid == request.auth.uid
        && resource.data.resultado == null;

      // RF-34/RF-35: titular registra o resultado uma única vez, com tier definido
      allow update: if isActive()
        && resource.data.uid == request.auth.uid
        && resource.data.tier != null
        && resource.data.resultado == null
        && request.resource.data.resultado != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['resultado'])
        && request.resource.data.resultado.validacoes.size() == 0;

      // RF-27/P16: titular reativa pitch do backlog (volta ao ciclo, zera avaliação)
      allow update: if isActive()
        && resource.data.uid == request.auth.uid
        && resource.data.ciclo == 'backlog'
        && request.resource.data.ciclo != 'backlog'
        && request.resource.data.tier == null
        && request.resource.data.resultado == null
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['ciclo', 'backlogDe', 'deadline', 'criadoEm', 'tier', 'resultado', 'reprovado', 'notas']);

      // RF-24..28 (P12): triagem — comitê e admins do Flux com os mesmos poderes
      allow update: if (hasRole('avaliador') || ehFluxAdmin())
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['tier', 'ciclo', 'backlogDe', 'reprovado']);

      // RF-38 (P13): cada membro do comitê grava apenas a própria validação
      allow update: if hasRole('avaliador')
        && resource.data.resultado != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['resultado'])
        && request.resource.data.resultado.diff(resource.data.resultado).affectedKeys().hasOnly(['validacoes'])
        && request.resource.data.resultado.validacoes
             .diff(resource.data.resultado.validacoes).affectedKeys()
             .hasOnly([request.auth.uid]);

      // RF-39: cada membro do comitê grava apenas as próprias notas
      allow update: if hasRole('avaliador')
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['notas'])
        && request.resource.data.notas.diff(resource.data.notas).affectedKeys()
             .hasOnly([request.auth.uid]);
    }

    // ── Ferramentas do hub (RF-57): administração do portal.
    //    O Flux é fixo em código e não passa por aqui. ──
    match /tools/{toolId} {
      allow read: if isActive();
      allow create, update, delete: if ehHubAdmin();
    }

    // ── Acessos ao Claude (RF-54): status da aplicação manual ──
    match /access/{userId} {
      allow read: if ehFluxAdmin();
      allow write: if ehFluxAdmin() || hasRole('avaliador');
    }

    // ── Projetos livres do Gestor de Tarefas (RF-44, reconciliado com o CRM/P15):
    //    multi-membro com papéis por projeto (admin | editor | leitor) ──
    function papelNoProjeto(projId) {
      return get(/databases/$(database)/documents/extraProjs/$(projId)).data
        .papeis[request.auth.uid];
    }

    function ehProjetoLivre(projId) {
      return exists(/databases/$(database)/documents/extraProjs/$(projId));
    }

    match /extraProjs/{projId} {
      allow read: if isActive() && request.auth.uid in resource.data.membrosIds;
      // criador entra como admin do projeto (trigger equivalente do CRM)
      allow create: if isActive()
        && request.resource.data.uid == request.auth.uid
        && request.auth.uid in request.resource.data.membrosIds
        && request.resource.data.papeis[request.auth.uid] == 'admin';
      // gestão de membros, arquivamento e edição: admin do projeto
      allow update: if isActive() && resource.data.papeis[request.auth.uid] == 'admin';
      // sair do projeto: o próprio membro remove apenas a si mesmo
      allow update: if isActive()
        && request.auth.uid in resource.data.membrosIds
        && !(request.auth.uid in request.resource.data.membrosIds)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['membrosIds', 'papeis']);
      // zona perigosa: excluir projeto — admin do projeto
      allow delete: if isActive() && resource.data.papeis[request.auth.uid] == 'admin';
    }

    // ── Quadros de tarefas (RF-45..48): um doc por projeto.
    //    membrosIds é denormalizado no quadro (projetos do Flux: só o titular) ──
    match /tarefas/{projectId} {
      allow read: if isActive()
        && (resource.data.uid == request.auth.uid
            || request.auth.uid in resource.data.membrosIds);
      allow create: if isActive()
        && (request.resource.data.uid == request.auth.uid
            || (ehProjetoLivre(projectId) && papelNoProjeto(projectId) in ['admin', 'editor']));
      // escrita: dono (Flux/criador) ou membro editor/admin do projeto livre; leitor não escreve
      allow update, delete: if isActive()
        && (resource.data.uid == request.auth.uid
            || (ehProjetoLivre(projectId) && papelNoProjeto(projectId) in ['admin', 'editor']));

      // ── Comentários por tarefa (CRM): thread na subcoleção ──
      match /comentarios/{comentarioId} {
        function quadroPai() {
          return get(/databases/$(database)/documents/tarefas/$(projectId)).data;
        }
        allow read: if isActive()
          && (quadroPai().uid == request.auth.uid
              || request.auth.uid in quadroPai().membrosIds);
        allow create: if isActive()
          && request.resource.data.autorId == request.auth.uid
          && (quadroPai().uid == request.auth.uid
              || (ehProjetoLivre(projectId) && papelNoProjeto(projectId) in ['admin', 'editor']));
        // editar: só o autor; excluir: o autor ou um admin do projeto
        allow update: if isActive() && resource.data.autorId == request.auth.uid;
        allow delete: if isActive()
          && (resource.data.autorId == request.auth.uid
              || (ehProjetoLivre(projectId) && papelNoProjeto(projectId) == 'admin')
              || quadroPai().uid == request.auth.uid);
      }
    }

    // ── Playbook (P15/P17 — importado do Supabase): instância global única.
    //    Leitura: qualquer usuário ativo (no hub não existe acesso anônimo).
    //    Escrita: SOMENTE editores do playbook (cada ferramenta gere o próprio
    //    acesso). A lista de editores é autogerida pelos editores; o admin do
    //    hub mantém acesso de socorro à lista. ──
    function ehEditorPlaybook() {
      return isActive()
        && request.auth.uid in get(/databases/$(database)/documents/playbook/config).data.editores;
    }

    match /playbook/{secao} {
      allow read: if isActive();
      // conteúdo só por editores — exceto Prospecção, colaborativa (qualquer ativo)
      allow write: if secao != 'config'
        && (ehEditorPlaybook() || (secao == 'prospeccao' && isActive()));
    }
    match /playbook/config {
      allow write: if ehEditorPlaybook() || ehHubAdmin();
    }
    match /playbookFeira/{eventoId} {
      // inclui leads (PII) e credenciais de portal: no Supabase eram
      // "só-autenticado" — aqui todo acesso já exige conta ativa do grupo
      allow read: if isActive();
      allow write: if ehEditorPlaybook();
    }

    // ── Logs de auditoria (RF-59): escrita por usuários ativos, leitura por admins ──
    match /logs/{logId} {
      allow read: if ehFluxAdmin() || ehHubAdmin();
      allow create: if isActive()
        && request.resource.data.quem == meDoc().nome
        && request.resource.data.keys().hasAll(['ts', 'quem', 'acao', 'det', 'tipo', 'at']);
    }
  }
}
