# Config do app web Firebase (Console → Configurações do projeto → Seus apps → SDK)
# Copie para .env.production.local com os valores reais antes do deploy.
VITE_FB_API_KEY=
VITE_FB_AUTH_DOMAIN=portal-flux-tecnofink.firebaseapp.com
VITE_FB_PROJECT_ID=portal-flux-tecnofink
VITE_FB_STORAGE_BUCKET=portal-flux-tecnofink.firebasestorage.app
VITE_FB_MESSAGING_SENDER_ID=
VITE_FB_APP_ID=

# Dica de domínio no seletor de contas Google (a restrição real é nas regras)
VITE_FB_HD_HINT=tecnofink.com

# true somente para desenvolvimento local com a Emulator Suite
VITE_USE_EMULATORS=false
