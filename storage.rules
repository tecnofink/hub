rules_version = '2';

// Anexos de evidência do resultado (RF-35). Portal interno: leitura para
// qualquer colaborador autenticado; escrita limitada a 20 MB por arquivo.
service firebase.storage {
  match /b/{bucket}/o {
    // evidências do resultado do Flux (RF-35)
    match /anexos/{projectId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 20 * 1024 * 1024;
    }

    // anexos de tarefas do Gestor (modelo do CRM: bucket anexos-tarefas)
    match /anexos-tarefas/{projectId}/{taskId}/{fileName} {
      allow read: if request.auth != null;
      allow write, delete: if request.auth != null
        && (request.resource == null || request.resource.size < 20 * 1024 * 1024);
    }

    // documentos do Playbook (logística, stands e planilhas de leads)
    match /playbook/{caminho=**} {
      allow read: if request.auth != null;
      allow write, delete: if request.auth != null
        && (request.resource == null || request.resource.size < 20 * 1024 * 1024);
    }
  }
}
