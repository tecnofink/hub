rules_version = '2';

// Portal interno: o Storage cruza a autorização com o Firestore (a barreira de
// domínio/conta ativa não pode viver só nas regras do Firestore). Qualquer conta
// Google obtém token, então "request.auth != null" NÃO basta.
service firebase.storage {
  match /b/{bucket}/o {
    // conta existente e ativa no portal
    function ativo() {
      return request.auth != null
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.ativo == true;
    }
    function tamanhoOk() {
      return request.resource.size < 20 * 1024 * 1024;
    }

    // evidências do resultado do Flux (RF-35) — só o titular do projeto grava/apaga
    match /anexos/{projectId}/{fileName} {
      function donoDoProjeto() {
        return ativo()
          && firestore.get(/databases/(default)/documents/projects/$(projectId)).data.uid == request.auth.uid;
      }
      allow read: if ativo();
      allow write: if donoDoProjeto() && tamanhoOk();
      allow delete: if donoDoProjeto();
    }

    // anexos de tarefas — só dono/membro do quadro (denormalizado em tarefas/{pid}.membrosIds).
    // Fecha o IDOR: antes qualquer autenticado apagava/sobrescrevia anexos de qualquer projeto.
    match /anexos-tarefas/{projectId}/{taskId}/{fileName} {
      function membroDoQuadro() {
        return ativo()
          && request.auth.uid in firestore.get(/databases/(default)/documents/tarefas/$(projectId)).data.membrosIds;
      }
      allow read: if membroDoQuadro();
      allow write: if membroDoQuadro() && tamanhoOk();
      allow delete: if membroDoQuadro();
    }

    // documentos do Playbook/Marketing (logística, stands, planilhas de leads) —
    // gravação/exclusão só por editores; leitura para conta ativa.
    match /playbook/{caminho=**} {
      function cfgPlaybook() {
        return firestore.get(/databases/(default)/documents/playbook/config).data;
      }
      function editorPlaybook() {
        return ativo() && request.auth.uid in cfgPlaybook().editores;
      }
      // leads (PII: nome/e-mail/telefone) ficam em playbook/leads/** — leitura só
      // por editor/observador/hubAdmin, espelhando a fronteira do Firestore
      // (playbookFeira). Sem isto, QUALQUER ativo listava e baixava as planilhas.
      function podeVerRestrito() {
        return ativo() && (
          request.auth.uid in cfgPlaybook().editores
          || request.auth.uid in cfgPlaybook().get('observadores', [])
          || firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.roles.hasAny(['hubAdmin', 'admin'])
        );
      }
      allow read: if ativo()
        && (!caminho.matches('leads/.*') || podeVerRestrito());
      allow write: if editorPlaybook() && tamanhoOk();
      allow delete: if editorPlaybook();
    }
  }
}
